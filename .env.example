# Copy to `.env.local` (gitignored) and fill in.
#
# IronStratos Pro Web Supabase — Auth (Google sign-in) + cloud identity.
# Both values are PUBLIC client credentials (the anon key is safe to ship; RLS
# protects data). Find them in the Supabase dashboard → Project Settings → API.
# Leaving them unset keeps the app fully anonymous/local (sign-in disabled).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
