# Copy to `.env.local` (gitignored) and fill in.
#
# IronStratos Pro Web Supabase — Auth (Google sign-in) + cloud identity.
# Both values are PUBLIC client credentials (the anon key is safe to ship; RLS
# protects data). Find them in the Supabase dashboard → Project Settings → API.
# Leaving them unset disables sign-in (the mandatory gate shows a clear error).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Native Google Sign-In — the Google Cloud "Web application" OAuth 2.0 client ID
# (the SAME one configured in the Supabase Google provider). PUBLIC value, safe
# to ship; required by @react-native-google-signin to mint an ID token Supabase
# accepts. Set in EAS env per environment; unset disables sign-in.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
